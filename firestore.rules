rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    // ===============================================================
    // Matches Collection
    // ===============================================================
    match /matches/{matchId} {
      // Anyone can read match metadata (names, submitted status)
      allow read: if true;
      
      // Anyone can create a match
      allow create: if true;
      
      // Anyone can update a match (to join or mark as submitted)
      // In a real app, we'd use auth, but the user requested no-auth.
      allow update: if true;

      // ===============================================================
      // Lists Subcollection
      // ===============================================================
      match /lists/{playerId} {
        // Allow reading if revealed OR if it's the player's own list 
        // (In this no-auth setup, we allow reading for now to support the WaitingView)
        allow read: if true;
        
        // Anyone can create a list (submit)
        allow create: if true;
        
        // Allow updating the selectedIndex for randomization
        allow update: if true;
      }
    }
  }
}
